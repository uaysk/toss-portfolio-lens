{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toss-portfolio-lens.local/contracts/worker/output-v1.schema.json",
  "title": "Toss Portfolio Lens compute worker output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "engine_version", "run_id", "job_kind", "status", "warnings"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "engine_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "job_kind": {
      "enum": [
        "backtest",
        "optimization",
        "walk_forward",
        "stress_test",
        "weight_sensitivity",
        "start_date_sensitivity",
        "rebalance_sensitivity",
        "cash_flow_sensitivity",
        "monte_carlo"
      ]
    },
    "status": { "enum": ["completed", "failed", "cancelled"] },
    "summary": {},
    "result": {},
    "error": {},
    "data_revision": { "type": "string", "minLength": 1, "maxLength": 128 },
    "request_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "content"],
        "properties": {
          "type": { "type": "string", "minLength": 1, "maxLength": 64 },
          "content": {},
          "row_count": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
