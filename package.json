{
  "name": "toss-portfolio-lens",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 0.0.0.0 --port 5173\" \"tsx watch server/index.ts\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:mysql": "tsx scripts/verify-mysql-storage.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@radix-ui/react-select": "2.2.5",
    "@radix-ui/react-slot": "1.2.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "express": "5.1.0",
    "lucide-react": "0.468.0",
    "mysql2": "^3.23.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "2.15.4",
    "tailwind-merge": "2.6.0"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/node": "22.15.30",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "10.4.21",
    "concurrently": "9.1.2",
    "postcss": "8.5.4",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "vitest": "3.2.3"
  }
}
