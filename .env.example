CLIENT_ID=
CLIENT_SECRET=
# 기본값은 토스증권 OAuth Client Credentials 인증입니다.
# TOSS_API_AUTH_MODE=oauth_client_credentials
# TOSS_API_BASE_URL=https://openapi.tossinvest.com

# Toss에 과거 USD/KRW 관측값이 없을 때 한국투자증권 일별 환율로 보완합니다.
# 모의투자 키는 demo(기본값), 실전투자 키는 real을 지정합니다.
KI_APP_KEY=
KI_APP_SECRET=
# KI_API_ENV=demo
# KI_API_REQUEST_INTERVAL_MS=600
# KI_API_TIMEOUT_MS=15000

# 단타 보조는 기본 비활성입니다. 활성화할 때 provider 계약/실측 한도를 반드시 명시합니다.
# SCALPING_ENABLED=true
# SCALPING_TOP_COUNT_MIN=5
# KIS WebSocket 실측 안전 한도에 맞춘 권장값입니다. 미국 종목은 표준 체결, 데이마켓
# 체결, 표준 세션 1호가의 3개 feed를 사용하므로 서버는 이 값과
# floor(KI_SCALPING_WS_MAX_SUBSCRIPTIONS / 3) 중 작은 값을 실제 공통 상한으로 사용합니다.
# SCALPING_TOP_COUNT_MAX=13
# TOSS_SCALPING_RANKING_MIN_INTERVAL_MS=
# TOSS_SCALPING_MARKET_DATA_MIN_INTERVAL_MS=
# TOSS_SCALPING_CHART_MIN_INTERVAL_MS=
# TOSS_SCALPING_STOCK_MIN_INTERVAL_MS=
# TOSS_SCALPING_MARKET_INFO_MIN_INTERVAL_MS=
# TOSS_SCALPING_CALENDAR_CACHE_TTL_MS=3600000
# TOSS_SCALPING_RANKING_MAX_COUNT=
# TOSS_SCALPING_PRICE_BATCH_SIZE=
# TOSS_SCALPING_CANDLE_MAX_COUNT=
# TOSS_SCALPING_TRADE_MAX_COUNT=
# KI_SCALPING_REST_REQUEST_INTERVAL_MS=
# 같은 키의 REST·WebSocket 허용 환경이 다른 경우에만 개별 override합니다.
# KI_SCALPING_REST_ENV=demo
# KI_SCALPING_WS_ENV=real
# 국내는 체결·호가 2개, 미국은 표준 체결·데이마켓 체결·표준 세션 1호가 3개를 구독합니다.
# 실측 계정에서 확인한 총 feed 한도를 넣어야 하며, 미국 데이마켓 HDFSASP0 호가는 공식
# 계약에 없어 만들지 않습니다. 계정별 실제 허용치를 확인하고 상향 후에는 재실측합니다.
# KI_SCALPING_WS_MAX_SUBSCRIPTIONS=40
# KI_SCALPING_WS_SUBSCRIBE_INTERVAL_MS=
# SCALPING_MINIMUM_VOLUME=
# 국내 거래대금 필터(KRW). 미국 전용 값이 없으면 이 값을 그대로 사용하므로 통화 단위를 확인합니다.
# SCALPING_MINIMUM_TRADING_AMOUNT=
# 미국 거래대금 필터(USD). 생략 시 SCALPING_MINIMUM_TRADING_AMOUNT로 fallback합니다.
# SCALPING_US_MINIMUM_TRADING_AMOUNT=
# SCALPING_MAXIMUM_SPREAD_BPS=
# SCALPING_WEIGHT_REALIZED_VOLATILITY=
# SCALPING_WEIGHT_NORMALIZED_ATR=
# SCALPING_WEIGHT_DAY_RANGE=
# SCALPING_WEIGHT_BOLLINGER_EXPANSION=
# SCALPING_WEIGHT_RELATIVE_VOLUME=
# SCALPING_WEIGHT_TRADING_AMOUNT=
# SCALPING_WEIGHT_SPREAD=
# SCALPING_FILTER_LOW_LIQUIDITY=true
# SCALPING_FILTER_WIDE_SPREAD=true
# SCALPING_BLOCKING_WARNING_CODES=
# SCALPING_CAUTION_WARNING_CODES=
# 차트/추론/검증 한도와 국내 KRX·NXT 통합 세션 정책입니다. NXT 기본 체결시간은 프리마켓
# 08:00~08:50, 애프터마켓 15:40~20:00이며, 두 휴장 구간은 예정된 공백으로 처리합니다.
# 미국은 Toss 일별 캘린더로 America/New_York 데이·프리·정규·애프터 세션을 DST 포함해 적용합니다.
# NXT 통합장 700분 x (현재 1 + 60분 완전봉 과거 6세션) 기준 최소값입니다.
# 창별 부분 tail은 Rust/AI 입력에서 제외하므로 기본 60개 분석 봉을 장중에도 보장합니다.
# SCALPING_WORKSPACE_BAR_LIMIT=4900
# 미국 fallback 확장 세션 1440분 x (현재 1 + RVOL 과거 5세션) 기준 최소값입니다.
# SCALPING_US_WORKSPACE_BAR_LIMIT=8640
# 브라우저로는 계산용 전체 이력이 아닌 차트용 최신 tail만 전송합니다.
# SCALPING_CHART_BAR_LIMIT=1000
# SCALPING_MINIMUM_ANALYSIS_BARS=60
# SCALPING_BAR_REFRESH_AFTER_MS=15000
# SCALPING_BAR_WATERMARK_ADVANCE_MS=1000
# 확정 봉 이후 Rust 최신 요약 batch를 합쳐 실행하는 SSE 연결별 debounce입니다.
# SCALPING_REALTIME_ANALYSIS_DEBOUNCE_MS=250
# 재연결 시 KIS 현재일 분봉 커서를 순회할 최대 요청 수입니다.
# SCALPING_RECOVERY_MAX_REQUESTS=30
# SCALPING_VOLUME_PROFILE_BUCKETS=24
# SCALPING_VOLUME_PROFILE_MAX_INSTRUMENTS=20
# SCALPING_RVOL_LOOKBACK_SESSIONS=5
# SCALPING_TRADE_FETCH_COUNT=50
# SCALPING_EVALUATION_ORIGIN_STRIDE_BARS=5
# SCALPING_NXT_PRE_MARKET_OPEN_KST=08:00
# SCALPING_NXT_PRE_MARKET_CLOSE_KST=08:50
# SCALPING_SESSION_OPEN_KST=09:00
# SCALPING_SESSION_CLOSE_KST=15:30
# SCALPING_NXT_AFTER_MARKET_OPEN_KST=15:40
# SCALPING_NXT_AFTER_MARKET_CLOSE_KST=20:00
# AI worker는 기본 Compose 스택에서 별도 이미지로 실행되며 내부 인증 WebSocket만 노출합니다.
# AI_WORKER_IMAGE=toss-portfolio-lens-ai-worker:local
# AI_COMPUTE_URL=ws://ai-worker:8765/ws/scalping-ai/v1
# AI_COMPUTE_AUTH_TOKEN_FILE=/run/ai-auth/token
# RFC1918 주소에 평문 ws로 연결할 때만 명시적으로 true로 설정합니다. 인터넷 구간은 wss를 사용합니다.
# AI_COMPUTE_ALLOW_INSECURE_PRIVATE_WS=false
# AI_COMPUTE_CONNECT_TIMEOUT_MS=10000
# AI_COMPUTE_TIMEOUT_MS=120000
# AI_COMPUTE_RECONNECT_BASE_MS=250
# AI_COMPUTE_RECONNECT_MAX_MS=10000
# AI_COMPUTE_MAX_IN_FLIGHT=4
# 사설 CA를 사용할 때 AI_TLS_SECRET_SOURCE에 CA 디렉터리를 mount하고 컨테이너 경로를 지정합니다.
# AI_COMPUTE_TLS_CA_FILE=
# 모든 표시 종목을 한 batch로 평가하려면 서버가 적용한 실제 최대 표시 종목 수 이상이어야 합니다.
# AI_COMPUTE_MAX_BATCH_SIZE=20
# Node와 Python AI worker에 동일하게 적용되는 WebSocket message 상한입니다.
# AI_MAX_REQUEST_BYTES=67108864
# AI_MAX_RESPONSE_BYTES=134217728
# AI_MIN_CONTEXT_BARS=64
# AI_MAX_CONTEXT_BARS=512
# AI_MAX_EVALUATION_ORIGINS=10000
# 기본값은 빈 named volume입니다. 검토된 offline cache를 쓸 때 절대 호스트 경로로 바꿉니다.
# AI_MODEL_CACHE_SOURCE=ai_model_cache
# 기본 local stack은 ai_auth named volume에 token을 원자 생성하고 web은 이를 읽기 전용으로 mount합니다.
# 원격 worker/main은 두 호스트에 같은 token file을 사전 배치한 절대 디렉터리를 각각 지정합니다.
# AI_AUTH_SECRET_SOURCE=ai_auth
# AI_TLS_SECRET_SOURCE=ai_tls
# AI_WEBSOCKET_GENERATE_AUTH_TOKEN=true
# AI_WEBSOCKET_MAX_CONNECTIONS=8
# AI_WEBSOCKET_QUEUE_CAPACITY=16
# AI_WEBSOCKET_MAX_IN_FLIGHT=4
# AI_WEBSOCKET_PING_INTERVAL_SECONDS=20
# AI_WEBSOCKET_PING_TIMEOUT_SECONDS=20
# AI_WEBSOCKET_CLOSE_TIMEOUT_SECONDS=10
# AI_WEBSOCKET_TLS_CERT_FILE=
# AI_WEBSOCKET_TLS_KEY_FILE=
# 기본 compose는 CPU이고, compose.ai-gpu.yaml을 함께 사용할 때만 cuda를 예약합니다.
# AI_DEVICE=cpu
# AI_ALLOW_CPU_FALLBACK=true
# AI_EXPECTED_CUDA_CAPABILITY=6.1
# AI_MICROBATCH_SIZE=4
# AI_MAX_SERIES=50
# AI_KRONOS_SAMPLE_COUNT=20
# 원격 GPU worker override 전용입니다. public address나 0.0.0.0 대신 private LAN 주소를 지정합니다.
# AI_REMOTE_BIND_ADDRESS=192.168.1.50
# AI_REMOTE_PORT=18765

# 읽기 전용 토스증권 호환 API를 직접 사용할 때 아래처럼 설정합니다.
# 이 모드에서는 CLIENT_ID와 CLIENT_SECRET을 생략할 수 있으며 /oauth2/token을 호출하지 않습니다.
# TOSS_API_AUTH_MODE=static_bearer
# TOSS_API_BASE_URL=https://tpl.uaysk.com/
# TOSS_API_BEARER_TOKEN=replace-with-the-read-only-api-token
# 웹 로그인과 이 앱의 읽기 전용 API Bearer 토큰으로 함께 사용합니다.
DASHBOARD_PASSWORD=replace-with-a-strong-password
SESSION_SECRET=replace-with-at-least-32-random-characters
PORT=3200
HOST=0.0.0.0
# Docker 배포 시 `APP_GIT_SHA=$(git rev-parse HEAD) docker compose up ...`로 주입합니다.
# APP_GIT_SHA=0123456789abcdef0123456789abcdef01234567
DB_PROVIDER=sqlite
DATABASE_PATH=./data/portfolio-history.sqlite
SNAPSHOT_REFRESH_HOURS=6
# 최신 candle 페이지의 캐시 TTL입니다. before가 있는 과거 페이지는 만료 없이 저장합니다.
CANDLE_CACHE_LATEST_TTL_MS=300000

# 생성된 보고서에서 사용할 외부 공개 주소입니다. 프로토콜을 생략하면 https://를 사용합니다.
PUBLIC_APP_URL=https://tpl.uaysk.com

# AI 포트폴리오 평가 보고서 생성
OPENAI_API_ENDPOINT=https://api.openai.com/v1
OPENAI_API_KEY=
# 비워 두면 /models를 조회해 사용 가능한 최신 GPT-5.6 계열을 자동 선택합니다.
# OPENAI_MODEL=gpt-5.6
# OPENAI_TIMEOUT_MS=60000

# AWS IAM 자격증명 체인으로 Amazon Bedrock을 사용할 때 설정합니다.
# REPORT_AI_PROVIDER=bedrock
# BEDROCK_REGION=eu-north-1
# BEDROCK_MODEL_ID=moonshotai.kimi-k2.5
# BEDROCK_TIMEOUT_MS=120000

# S3_BUCKET이 없으면 REPORTS_PATH에 로컬 JSON으로 저장합니다.
REPORTS_PATH=./data/reports
# S3_BUCKET=portfolio-reports
# S3_REGION=ap-northeast-2
# S3_PREFIX=portfolio-reports
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# MinIO 등 S3 호환 저장소를 사용할 때만 설정합니다.
# S3_ENDPOINT=https://s3.example.com
# S3_FORCE_PATH_STYLE=true

# DB_PROVIDER는 sqlite, mysql, postgresql 중 하나를 지정합니다.
# 선택한 외부 DB의 연결이나 마이그레이션이 실패하면 앱 시작을 중단합니다.
# DB_PROVIDER=postgresql일 때 아래 값을 모두 설정합니다.
# POSTGRES_URL=postgresql://portfolio:password@postgres-host:5432/portfolio_lens
# 또는 POSTGRES_URL 대신 다음 값을 각각 설정합니다.
# POSTGRES_HOST=postgres-host
# Docker 내부에서 POSTGRES_HOST를 별도 IP로 매핑해야 할 때만 지정합니다.
# POSTGRES_DOCKER_HOST_IP=host-gateway
# POSTGRES_PORT=5432
# POSTGRES_USER=portfolio
# POSTGRES_PASSWORD=replace-with-a-strong-database-password
# POSTGRES_DATABASE=portfolio_lens
# POSTGRES_CONNECT_TIMEOUT_MS=3000
# POSTGRES_CONNECT_TIMEOUT_SECONDS=5
# POSTGRES_SSL=true
# POSTGRES_CA_HOST_PATH=./data/certs/postgres-ca.crt
# POSTGRES_SSL_CA_PATH=/app/certs/postgres-ca.crt
# POSTGRES_SSL_REJECT_UNAUTHORIZED=true

# DB_PROVIDER=mysql일 때 아래 값을 모두 설정합니다. MariaDB도 같은 설정을 사용합니다.
# MYSQL_URL=mysql://portfolio:password@mysql-host:3306/portfolio_lens
# 또는 MYSQL_URL 대신 다음 값을 각각 설정합니다.
# MYSQL_HOST=mysql-host
# MYSQL_PORT=3306
# MYSQL_USER=portfolio
# MYSQL_PASSWORD=replace-with-a-strong-database-password
# MYSQL_DATABASE=portfolio_lens
# MYSQL_CONNECT_TIMEOUT_MS=3000
# MYSQL_SSL=false
# MYSQL_SSL_CA_PATH=/app/certs/global-bundle.pem
# MYSQL_SSL_REJECT_UNAUTHORIZED=true

# ChatGPT/Codex MCP 연결은 기본 비활성입니다. 전체 OAuth 설정은 .env.chatgpt.example을 복사해 사용합니다.
MCP_ENABLED=false
# 계산은 개발 호환용 inline, 저지연 Rust UDS(rust_socket), PostgreSQL durable queue(external) 중 선택합니다.
# EXECUTION_MODE=rust_socket
# RUST_COMPUTE_SOCKET=/app/run/compute.sock
# RUST_COMPUTE_POOL_SIZE=2
# RUST_COMPUTE_TIMEOUT_MS=300000
# RUST_WORKER_RESULT_POLL_MS=250
# RUST_WORKER_RESULT_DEADLINE_MS=300000
# 이전 PYTHON_WORKER_RESULT_* 이름도 롤백 호환용으로 인식합니다.
# RUST_WORKER_ID=worker-1
# RUST_WORKER_POLL_MS=250
# RUST_WORKER_LEASE_MS=30000
# RUST_WORKER_HEARTBEAT_MS=5000
# RUST_WORKER_RECOVERY_MS=10000
# MCP_AUTH_MODE=oauth
# MCP_RESOURCE_URL=https://portfolio.example.com/mcp
# MCP_OAUTH_ISSUER=https://portfolio.example.com
# MCP_OAUTH_CLIENT_ID=toss-portfolio-lens-chatgpt
# MCP_OAUTH_CLIENT_NAME=Toss Portfolio Lens ChatGPT
# MCP_OAUTH_CLIENT_SECRET_FILE=/run/secrets/mcp-oauth-client-secret
# MCP_OAUTH_SIGNING_KEY_FILE=/run/secrets/mcp-oauth-signing-key
# MCP_OAUTH_REDIRECT_URI=https://chatgpt.com/replace-with-registered-callback
# MCP_OAUTH_AUTO_APPROVE=false
# MCP_ACCESS_TOKEN_TTL_SECONDS=3600
# MCP_REFRESH_TOKEN_TTL_SECONDS=2592000
# MCP_AUTH_CODE_TTL_SECONDS=300
# MCP_OAUTH_SESSION_TTL_SECONDS=900
# MCP_MAX_REQUESTS_PER_MINUTE=60
# MCP_MAX_CONCURRENT_RUNS=1
# MCP_MAX_RUNS_PER_SUBJECT=2
# MCP_MAX_ASSETS=20
# MCP_MAX_CANDIDATE_BUDGET=2000
# MCP_MAX_QUEUED_RUNS=4
# MCP_RUN_DEADLINE_MS=120000
# MCP_MAX_DATE_RANGE_YEARS=20
# MCP_INLINE_RESULT_MAX_ROWS=1000
# MCP_INLINE_RESULT_MAX_BYTES=204800
# MCP_AUDIT_RETENTION_DAYS=90
# MCP_ALLOWED_ORIGINS=
